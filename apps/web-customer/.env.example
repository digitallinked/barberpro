# BarberPro Customer Portal — Environment Variables
# Copy this file to .env.local and fill in your values.

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Supabase — same project as apps/web
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe — same account as web-shop; webhook should point at web-shop /api/webhooks/stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_CUSTOMER_PLUS_PRICE_ID=

# Resend — used for contact form emails
RESEND_API_KEY=re_your-resend-key-here
RESEND_FROM_EMAIL=BarberPro <noreply@barberpro.my>

# Google Maps / Places API — get from: console.cloud.google.com > APIs & Services > Credentials
# Enable: Maps JavaScript API + Places API. Restrict key to HTTP referrers for your domains.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
