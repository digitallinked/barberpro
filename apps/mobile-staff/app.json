{
  "expo": {
    "name": "BarberPro Staff",
    "slug": "barberpro-staff",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "barberpro-staff",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "my.barberpro.staff"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "my.barberpro.staff"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1a1a2e"
        }
      ]
    ]
  }
}
