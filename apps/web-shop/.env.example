# BarberPro Web App — Environment Variables
# Copy this file to .env.local and fill in your values.

# App URL (used for absolute URLs, metadata, and redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Customer-facing app URL — required in production for walk-in QR codes (defaults to NEXT_PUBLIC_APP_URL)
# NEXT_PUBLIC_CUSTOMER_APP_URL=https://barberpro.my

# Supabase — get from: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe — get from: Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_test_your-key-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Stripe Price IDs — get from: Stripe Dashboard > Products > Prices
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_starter-monthly-id-here
NEXT_PUBLIC_STRIPE_PROFESSIONAL_PRICE_ID=price_professional-monthly-id-here
NEXT_PUBLIC_STRIPE_STARTER_YEARLY_PRICE_ID=price_1TJkDSBGoz93lNFYuMWAHOjN
NEXT_PUBLIC_STRIPE_PROFESSIONAL_YEARLY_PRICE_ID=price_1TJkDVBGoz93lNFYcScXNTmr

# Cron secret — used to secure scheduled API routes (set same value in Vercel Cron config)
CRON_SECRET=your-cron-secret-here

# Resend — get from: resend.com > API Keys
RESEND_API_KEY=re_your-resend-key-here
RESEND_FROM_EMAIL=BarberPro <noreply@barberpro.my>

# Sentry (optional) — get from: sentry.io > Project Settings > Client Keys (DSN)
# NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Google Maps / Places API — get from: console.cloud.google.com > APIs & Services > Credentials
# Enable: Maps JavaScript API + Places API. Restrict key to HTTP referrers for your domains.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
