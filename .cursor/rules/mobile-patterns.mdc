**No StyleSheet.create()** — use NativeWind classes exclusively.

## Data Fetching

Use TanStack Query same as web:

```typescript
import { useQuery } from '@tanstack/react-query';

export function useShopQueue(branchId: string) {
  return useQuery({
    queryKey: ['queue', branchId],
    queryFn: async () => {
      const { data, error } = await supabase
        .from('queue_tickets')
        .select('*')
        .eq('branch_id', branchId)
        .eq('queue_day', new Date().toISOString().split('T')[0]);
      if (error) throw error;
      return data;
    },
  });
}
```

For live queue data, use Supabase Realtime instead of polling.

## Realtime Subscriptions

```typescript
import { useEffect } from 'react';
import { supabase } from '@/lib/supabase';

export function useQueueRealtime(branchId: string, onUpdate: () => void) {
  useEffect(() => {
    const channel = supabase
      .channel(`queue:${branchId}`)
      .on('postgres_changes', {
        event: '*',
        schema: 'public',
        table: 'queue_tickets',
        filter: `branch_id=eq.${branchId}`,
      }, onUpdate)
      .subscribe();

    return () => { supabase.removeChannel(channel); };
  }, [branchId]);
}
```

## Key Mobile-Specific Rules

- **No browser APIs** (`localStorage`, `document`, `window`) — use React Native equivalents
- **Platform checks** when needed: `import { Platform } from 'react-native'`
- **Safe area** — always wrap root screens with `SafeAreaView` or use `useSafeAreaInsets()`
- **Keyboard avoiding** — use `KeyboardAvoidingView` on forms
- **FlatList not ScrollView** for long lists — FlatList virtualizes; ScrollView renders all items
- **Loading states** — always show `ActivityIndicator` while data fetches
- **Error states** — always handle query errors with a user-facing error message + retry button

## EAS Commands

```bash
# Development build (needed for Expo Router + native modules)
eas build --profile development --platform ios
eas build --profile development --platform android

# Production build
eas build --profile production --platform all

# OTA update (JS-only changes, no native changes)
eas update --branch production --message "Fix queue display"

# Submit to stores
eas submit --platform ios
eas submit --platform android
```
