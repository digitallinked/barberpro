{
  "name": "barberpro-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm dev:shop",
    "dev:shop": "pnpm --filter @barberpro/web-shop dev",
    "dev:admin": "pnpm --filter @barberpro/web-admin dev",
    "dev:customer": "pnpm --filter @barberpro/web-customer dev",
    "build:shop": "pnpm --filter @barberpro/web-shop build",
    "build:admin": "pnpm --filter @barberpro/web-admin build",
    "build:customer": "pnpm --filter @barberpro/web-customer build",
    "start:shop": "pnpm --filter @barberpro/web-shop start",
    "start:admin": "pnpm --filter @barberpro/web-admin start",
    "start:customer": "pnpm --filter @barberpro/web-customer start",
    "lint:shop": "pnpm --filter @barberpro/web-shop lint",
    "lint:admin": "pnpm --filter @barberpro/web-admin lint",
    "lint:customer": "pnpm --filter @barberpro/web-customer lint",
    "typecheck": "pnpm typecheck:shop && pnpm typecheck:admin && pnpm typecheck:customer && pnpm typecheck:mobile",
    "typecheck:shop": "pnpm --filter @barberpro/web-shop typecheck",
    "typecheck:admin": "pnpm --filter @barberpro/web-admin typecheck",
    "typecheck:customer": "pnpm --filter @barberpro/web-customer typecheck",
    "dev:mobile": "pnpm --filter @barberpro/mobile-customer dev",
    "typecheck:mobile": "pnpm --filter @barberpro/mobile-customer typecheck && pnpm --filter @barberpro/mobile-staff typecheck"
  },
  "devDependencies": {}
}
